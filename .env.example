# PostgreSQL connection string.
# Local example:
# DATABASE_URL="postgresql://postgres:postgres@localhost:5432/recipes"
# Production example is configured in Coolify and must not be committed.
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/recipes"

# Auth.js / NextAuth secret.
# Generate a strong secret for production.
AUTH_SECRET="change-me"

# Base URL of the application.
# Local:
# NEXTAUTH_URL="http://localhost:3000"
# Production:
# NEXTAUTH_URL="https://recipes.voreno.cz"
NEXTAUTH_URL="http://localhost:3000"

# Registration is disabled by default.
# Set to "true" only when creating accounts.
ALLOW_REGISTRATION="false"

# Required when registration is enabled.
REGISTRATION_INVITE_CODE="change-me"